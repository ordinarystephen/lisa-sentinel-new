# Lisa-Sentinel environment configuration
# Copy to .env and fill in. Domino-injected env vars take precedence over .env values.

# ---------------------------------------------------------------------------
# Azure OpenAI (LLM)
# ---------------------------------------------------------------------------
# Required: name of the Azure OpenAI deployment to call.
AZURE_OPENAI_DEPLOYMENT=
# Required: Azure OpenAI API version (e.g. 2024-08-01-preview).
OPENAI_API_VERSION=
# Optional: Azure OpenAI endpoint. Leave blank to use the team's tenant default.
AZURE_OPENAI_ENDPOINT=
# Optional: name of the Azure OpenAI embeddings deployment.
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=

# ---------------------------------------------------------------------------
# Azure Document Intelligence
# ---------------------------------------------------------------------------
# Required for the docintel parser. Use Domino's local nginx proxy:
#   https://127.0.0.1:8443
# Do NOT call *.cognitiveservices.azure.com directly.
AZURE_DOCINTEL_ENDPOINT=
# Optional: Document Intelligence API version.
DOCINTEL_API_VERSION=2024-11-30

# ---------------------------------------------------------------------------
# Parser selection
# ---------------------------------------------------------------------------
# One of: docintel-official (default) | pypdf | docintel-risklab | ocr-fallback
MEMO_PDF_PARSER=docintel-official

# ---------------------------------------------------------------------------
# Doc store
# ---------------------------------------------------------------------------
# Optional: root directory for the content-addressed document store.
# Defaults to <repo_root>/doc_store. Set this when Domino mounts a
# persistent volume you want extractions to land on.
DOC_STORE_DIR=

# ---------------------------------------------------------------------------
# Worker pools
# ---------------------------------------------------------------------------
MEMO_PDF_WORKERS=4
MEMO_QUESTION_WORKERS=4

# ---------------------------------------------------------------------------
# Embeddings
# ---------------------------------------------------------------------------
MEMO_CHUNK_SIZE=1500
MEMO_CHUNK_OVERLAP=200

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LISA_LOG_LEVEL=INFO
# Per-run log artefact directory. Reserved for future per-job artefact
# folders; structured stderr logs (the active operator surface) work
# regardless of this value.
#
# Local dev: leave as "logging" — resolves to <repo>/logging relative to
# whatever CWD the app boots from.
#
# Domino: set to an ABSOLUTE path inside the project workspace, e.g.
#   LISA_LOG_DIR=/mnt/<project>/lisa-sentinel/logging
# A relative path can drift if Domino's launcher changes CWD between
# restarts, leaving artefacts somewhere unexpected.
LISA_LOG_DIR=logging
