.env.*.local

# ─── App runtime artifacts ────────────────────────────────────────────────
# Per-run logging folders (the structure stays, the contents don't)
logging/*/
!logging/.gitkeep

# Document store (uploaded PDFs and extractions are local data)
doc_store/
!doc_store/.gitkeep

# Dev panel prompt overrides (local experimentation)
app/prompts/dev_overrides/

# ─── Logs ─────────────────────────────────────────────────────────────────
*.log

